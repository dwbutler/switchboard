{
  "name": "switchboard-cli",
  "version": "0.1.0",
  "description": "Switchboard CLI app — Commander + Ink terminal interface for the switchboard monorepo",
  "type": "module",
  "bin": {
    "switchboard": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@switchboard/core": "workspace:*",
    "commander": "^14.0.3",
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
